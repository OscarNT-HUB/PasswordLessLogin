<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PasswordLessLogin" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#7C4DFF</item>
        <item name="colorPrimaryVariant">#651FFF</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF4081</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A2E</item>
        <item name="android:statusBarColor">#651FFF</item>
    </style>

    <style name="CardContainer" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
        <item name="contentPadding">24dp</item>
    </style>

    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#7C4DFF</item>
        <item name="boxStrokeWidth">1.5dp</item>
        <item name="hintTextColor">#7C4DFF</item>
    </style>

    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#7C4DFF</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">#7C4DFF</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">#7C4DFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="LinkText" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">#7C4DFF</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>
